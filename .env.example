# Server (web app)
PORT=3000
NODE_ENV=development
JWT_SECRET=your-very-secure-secret-key-change-this-in-production-minimum-32-chars
MONGODB_URI=mongodb://localhost:27019/fastify-app

# Redis (for BullMQ + sessions) (Docker runs on port 6381)
REDIS_URL=redis://localhost:6381

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Instagram Login (for authenticated scraping)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Scraper Worker (Docker container)
SCRAPE_CONCURRENCY=1
SCRAPE_TIMEOUT_MS=30000
