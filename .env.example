# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=your-very-secure-secret-key-change-this-in-production-minimum-32-chars

# MongoDB (Docker runs on port 27019)
MONGODB_URI=mongodb://localhost:27019/fastify-app

# Test Database (E2E tests)
MONGODB_URI_TEST=mongodb://localhost:27019/fastify-app-e2e-test

# Redis (for BullMQ) (Docker runs on port 6381)
REDIS_URL=redis://localhost:6381
